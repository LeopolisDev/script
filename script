    dot.Anchored = true
    dot.CanCollide = false
    dot.CanTouch = false
    dot.CanQuery = false
    dot.Parent = PredictionFolder
    dots[i] = dot
end

local function GetVelocity(power, angle, putting)
    local v4 = (power or 0)
    local v52 = (angle or 0)
    local rawVel
    if putting then
        rawVel = Vector3.new(math.cos(math.rad(v52)) * (v4 * 0.45 + 5), 0, 0)
    else
        local v72 = math.clamp((v4 * 31.35) ^ 0.5714285714285714 + 3, 10, math.huge)
        rawVel = Vector3.new(math.cos(math.rad(v52)) * v72, math.sin(math.rad(v52)) * v72, 0)
    end
    -- Apply the learned multiplier
    return rawVel * Config.VelocityMult
end

local lastShotData = nil -- Track power/angle when shot was made

local function UpdateTrajectory()
    if not DataModule or not Config.Prediction or Config.BallControl then
        for i = 1, MAX_DOTS do dots[i].Transparency = 1 end
        return
    end

    local holeData = DataModule.CurrentHoleData
    local globalData = DataModule.GlobalData
    if not holeData or not globalData or not globalData.Ball then
        for i = 1, MAX_DOTS do dots[i].Transparency = 1 end
        return
    end

    -- Robust Aiming Detection
    local isAiming = true
    pcall(function()
        if holeData.HoleActive == false or holeData.WaitingForServer == true or holeData.BallInRest == false then isAiming = false end
    end)
    
    -- Calibration logic: Catch the shot launch
    local ball = globalData.Ball
    if not isAiming and not Config.AutoCalibrated then
        local currentVel = ball.AssemblyLinearVelocity
        if currentVel.Magnitude > 1 and lastShotData then
            -- Compare actual velocity with expected velocity
            local expected = GetVelocity(lastShotData.Power, lastShotData.Angle, lastShotData.Putting)
            if expected.Magnitude > 0 then
                Config.VelocityMult = currentVel.Magnitude / expected.Magnitude
                Config.AutoCalibrated = true
                print("Sharpness Calibrated: Multiplier set to " .. Config.VelocityMult)
            end
        end
    end

    if not isAiming then
        for i = 1, MAX_DOTS do dots[i].Transparency = 1 end
        return
    end

    -- Store shot data for calibration
    lastShotData = { Power = holeData.CurrentPower, Angle = holeData.CurrentAngle, Putting = holeData.Putting }

    local startPos = Vector3.new(0,0,0)
    pcall(function()
        local b = ball:IsA("Model") and ball.PrimaryPart or ball
        startPos = b.Position
    end)
    local currentPos = Vector3.new(startPos.X, startPos.Y, 0) -- Lock to 2D plane (Z=0)

    local currentVel = GetVelocity(holeData.CurrentPower, holeData.CurrentAngle, holeData.Putting)
    local dt = 1/60
    local GRAVITY = Vector3.new(0, -workspace.Gravity, 0)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {workspace.Balls, workspace.Characters, PredictionFolder}

    local bounceCount = 0
    local maxBounces = 20
    local stopIdx = MAX_DOTS
    local bias = Config.PredictionBias or 0.7275

    for i = 1, MAX_DOTS do
        local dot = dots[i]
        local success = pcall(function()
            dot.Position = currentPos
            dot.Transparency = 0.3
            dot.Color = holeData.Putting and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(255, 170, 0)

            local stepVel = currentVel * dt + 0.5 * GRAVITY * dt * dt
            -- Raycast with Z=0 strictly
            local result = workspace:Raycast(currentPos, Vector3.new(stepVel.X, stepVel.Y, 0), rayParams)

            if result then
                local hitPart = result.Instance
                local hitName = hitPart.Name
                
                local inHazard = (hitName == "Sand" or hitName == "Water" or hitName == "OutOfBounds")
                if hitName == "End" or inHazard then
                    if inHazard then dot.Color = Color3.fromRGB(255, 0, 0) end
                    stopIdx = i
                    error("stop")
                end

                if bounceCount < maxBounces then
                    bounceCount = bounceCount + 1
                    local normal = result.Normal
                    normal = Vector3.new(normal.X, normal.Y, 0).Unit -- Keep 2D
                    
                    local restitution = 0.6 * (0.8 + bias * 0.2)
                    local vn = currentVel:Dot(normal) * normal
                    local vt = currentVel - vn
                    
                    currentVel = vt * (0.8 * bias) - vn * restitution
                    currentVel = Vector3.new(currentVel.X, currentVel.Y, 0)
                    
                    currentPos = result.Position + normal * 0.1
                    currentPos = Vector3.new(currentPos.X, currentPos.Y, 0)
                else
                    stopIdx = i
                    error("stop")
                end
            else
                currentPos = currentPos + stepVel
                currentPos = Vector3.new(currentPos.X, currentPos.Y, 0)
                currentVel = currentVel + GRAVITY * dt
            end
            
            if currentVel.Magnitude < 0.01 then
                stopIdx = i
                error("stop")
            end
        end)
        if not success then break end
    end

    for i = stopIdx + 1, MAX_DOTS do dots[i].Transparency = 1 end
end

RunService.Heartbeat:Connect(function()
    pcall(function()
        if not DataModule then return end
        local globalData = DataModule.GlobalData
        local holeData = DataModule.CurrentHoleData
        local ball = globalData and globalData.Ball
        if Config.MaxPower and holeData and (holeData.CurrentPower or 0) > 0 then holeData.CurrentPower = 100 end
        if Config.BallControl and ball then
            workspace.CurrentCamera.CameraSubject = ball
            ball.AssemblyLinearVelocity = Vector3.new(0,0,0)
            ball.Anchored = false
            local moveDir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.Up)    then moveDir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.Down)  then moveDir += Vector3.new(0,-1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.Left)  then moveDir += Vector3.new(-1,0,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.Right) then moveDir += Vector3.new(1,0,0) end
            if moveDir.Magnitude > 0 then ball.CFrame = ball.CFrame + (moveDir.Unit * Config.ControlSpeed) end
            ball.CFrame = CFrame.new(ball.Position.X, ball.Position.Y, 0)
        end
        if Config.TeleportEnabled and ball then
            local LoadedMap = workspace:FindFirstChild("LoadedMap")
            local Map = LoadedMap and LoadedMap:FindFirstChildOfClass("Folder")
            local holePart = Map and Map:FindFirstChild("Hole", true)
            if holePart then
                pcall(function()
                    if ball:IsA("Model") then ball:SetPrimaryPartCFrame(holePart.CFrame) else ball.CFrame = holePart.CFrame end
                end)
            end
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait()
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        end
    end)
end)

