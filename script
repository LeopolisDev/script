local function updateGravity(x)
    local percent = math.clamp((x - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
    local grav = math.floor(percent * 200)
    workspace.Gravity = grav
    fill.Size = UDim2.new(percent, 0, 1, 0)
    valueText.Text = "Gravity: " .. grav
end

local function updateBias(x)
    local percent = math.clamp((x - biasFrame.AbsolutePosition.X) / biasFrame.AbsoluteSize.X, 0, 1)
    Config.PredictionBias = 0.5 + percent
    biasFill.Size = UDim2.new(percent, 0, 1, 0)
    biasText.Text = "Prediction Dist: " .. math.floor(Config.PredictionBias * 10000)/100 .. "%"
end

